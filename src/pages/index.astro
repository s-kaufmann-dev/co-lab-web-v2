---
import Layout from '../layouts/Layout.astro';
import SplineHero from '../components/react/SplineHero.jsx';
import BentoPortfolio from '../components/react/BentoPortfolio.jsx';
import ServicesSection from '../components/react/ContainerScroll.jsx';
import ShaderBackground from '../components/react/ShaderBackground.jsx';
import AnimatedTestimonials from '../components/react/AnimatedTestimonials.jsx';
import { MagneticButton, Highlighter } from '../components/react/InteractiveElements.jsx';
---

<Layout title="Co-Lab-Web | Neural Design & Boutique Automation">
	<ShaderBackground client:only="react" />
	
	<SplineHero client:only="react" />

	<section id="about" class="py-48 px-[5vw] bg-black border-y border-white/5 relative z-10">
		<div class="max-w-7xl">
			<div class="mb-24">
				<span class="text-accent text-sm font-mono uppercase tracking-[0.5em] mb-8 block">About the Matrix</span>
				<h2 class="text-[12vw] md:text-[8vw] font-black uppercase tracking-[-0.05em] leading-[0.8]">
					We build the <br/>
					<span class="text-accent">Neural Future</span> <br/>
					of the web.
				</h2>
			</div>
			
			<div class="grid md:grid-cols-2 gap-24 items-start">
				<div class="space-y-12">
					<p class="text-3xl md:text-4xl text-white font-medium leading-[1.1] tracking-tighter">
						Co-Lab-Web is a high-performance digital boutique operating at the <Highlighter client:only="react">edge of design</Highlighter> and artificial intelligence.
					</p>
					<p class="text-xl text-neutral-500 leading-relaxed max-w-md">
						We don't follow trends. We architect systems that combine <span class="text-white">brutalist aesthetics</span> with <span class="text-white">intelligent automation</span> to deliver unfair advantages for our partners.
					</p>
				</div>
				
				<div class="flex flex-col gap-12 md:items-end">
					<div class="text-left md:text-right space-y-2">
						<p class="text-neutral-500 font-mono text-xs uppercase tracking-widest">Established // 2024</p>
						<p class="text-neutral-500 font-mono text-xs uppercase tracking-widest">Logic // Brutalism & Performance</p>
						<p class="text-neutral-500 font-mono text-xs uppercase tracking-widest">Status // Digital Native</p>
					</div>
					<MagneticButton client:only="react" className="w-fit">Start Collaboration</MagneticButton>
				</div>
			</div>
		</div>
	</section>

	<ServicesSection client:only="react" />

	<BentoPortfolio client:only="react" />

	<AnimatedTestimonials client:only="react" />

	<footer class="py-32 px-[5vw] bg-black border-t border-white/5 relative z-10">
		<div class="flex flex-col lg:flex-row justify-between items-start gap-24">
			<div class="max-w-xl">
				<h2 class="text-6xl font-black uppercase tracking-[-0.08em] mb-8 leading-none">Co-Lab<br/>Web</h2>
				<p class="text-neutral-500 text-lg font-medium leading-tight mb-12">
					Designed and engineered for those who demand technical excellence and visual provocation.
				</p>
				<div class="flex gap-4">
					<div class="w-3 h-3 rounded-full bg-accent animate-pulse"></div>
					<span class="text-xs font-mono uppercase tracking-widest text-neutral-600">All systems operational</span>
				</div>
			</div>
			
			<div class="grid grid-cols-2 md:grid-cols-3 gap-16 lg:gap-32 w-full lg:w-auto">
				<div class="flex flex-col gap-6">
					<span class="text-[0.6rem] uppercase tracking-[0.4em] text-accent font-mono">Socials</span>
					<a href="#" class="text-xl font-bold uppercase tracking-tighter hover:text-accent transition-colors">LinkedIn</a>
					<a href="#" class="text-xl font-bold uppercase tracking-tighter hover:text-accent transition-colors">Instagram</a>
					<a href="#" class="text-xl font-bold uppercase tracking-tighter hover:text-accent transition-colors">GitHub</a>
				</div>
				<div class="flex flex-col gap-6">
					<span class="text-[0.6rem] uppercase tracking-[0.4em] text-accent font-mono">Contact</span>
					<a href="mailto:hello@co-lab-web.de" class="text-xl font-bold uppercase tracking-tighter hover:text-accent transition-colors">hello@co-lab-web.de</a>
					<a href="#" class="text-xl font-bold uppercase tracking-tighter hover:text-accent transition-colors">Book a Call</a>
				</div>
				<div class="flex flex-col gap-6 hidden md:flex">
					<span class="text-[0.6rem] uppercase tracking-[0.4em] text-accent font-mono">Legal</span>
					<a href="#" class="text-xs font-mono uppercase tracking-widest hover:text-white transition-colors">Imprint</a>
					<a href="#" class="text-xs font-mono uppercase tracking-widest hover:text-white transition-colors">Privacy</a>
				</div>
			</div>
		</div>
		
		<div class="mt-48 text-[22vw] font-black uppercase leading-[0.7] opacity-[0.03] select-none pointer-events-none tracking-[-0.1em] text-center w-full">
			CO-LAB-WEB
		</div>
	</footer>
</Layout>
